# ===================================
# Hemorrhage Detection System
# Environment Configuration
# ===================================

# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=hemorrhage_detection
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/hemorrhage_detection

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
API_PORT=8000
FRONTEND_PORT=3000
DEBUG=false

# File Upload
MAX_UPLOAD_SIZE_MB=500
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.dcm,.dicom

# ML Model Configuration
MODEL_PATH=./ml/models/trained
MODEL_NAME=hemorrhage_hybrid_cnn
BATCH_SIZE=8
CONFIDENCE_THRESHOLD=0.5
SEVERITY_THRESHOLD_MODERATE=0.3
SEVERITY_THRESHOLD_SEVERE=0.7

# Notification Settings
CRITICAL_SEVERITY_THRESHOLD=70
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hemorrhage-detection.local

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Production Settings
# Uncomment for production
# DEBUG=false
# ALLOWED_ORIGINS=https://your-domain.com
